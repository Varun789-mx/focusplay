{
    "manifest_version": 3,
    "name": "FocusPlay",
    "version": "1.0.0",
    "description": "helps you focus on one thing ",
    "permissions": [
        "storage",
        "activeTab",
        "tabs",
        "scripting"
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": "focus.png"
    },
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    }
}